{
  "name": "smart-stadium-experience",
  "version": "2.0.0",
  "description": "Premium smart stadium experience for IPL attendees — crowd management, real-time coordination, and digital ticketing",
  "main": "app.js",
  "scripts": {
    "test": "jest --coverage --verbose",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .js",
    "start": "npx serve -s . -l 8080",
    "dev": "npx serve -s . -l 8080",
    "predeploy": "npm test",
    "deploy": "npx gh-pages -d ."
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "eslint": "^8.56.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "collectCoverageFrom": [
      "app.js",
      "firebase-config.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    }
  }
}
