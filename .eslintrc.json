{
  "env": {
    "browser": true,
    "es2021": true,
    "jest": true,
    "serviceworker": true,
    "node": true
  },
  "globals": {
    "firebase": "readonly",
    "firebaseService": "readonly"
  },
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-undef": "error",
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-new-func": "error",
    "eqeqeq": ["error", "always"],
    "curly": "error",
    "no-var": "error",
    "prefer-const": "warn",
    "no-throw-literal": "error",
    "no-alert": "warn",
    "no-console": "off"
  }
}
